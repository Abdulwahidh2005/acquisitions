NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Use your real Neon Cloud database URL in production.
DATABASE_URL=postgres://user:password@your-production-host.neon.tech/dbname?sslmode=require

# Do not set NEON_LOCAL_FETCH_ENDPOINT in production.
ARCJET_KEY=your_arcjet_key
JWT_SECRET=change_me_for_production
JWT_EXPIRATION=1d
