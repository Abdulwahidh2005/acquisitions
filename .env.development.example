NODE_ENV=development
PORT=3000
APP_PORT=3001
NEON_LOCAL_PORT=5432
LOG_LEVEL=info

# App connects to Neon Local inside docker-compose.dev.yml.
DATABASE_URL=postgres://neon:npg@neon-local:5432/?sslmode=require
NEON_LOCAL_FETCH_ENDPOINT=http://neon-local:5432/sql

# Required by the neon-local container to create ephemeral branches.
NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id

# Optional: omit to branch from the project's default branch.
PARENT_BRANCH_ID=

# App secrets.
ARCJET_KEY=ajkey_01kqh0brp7ed6twx7eeyxyvhn0
JWT_SECRET=change_me_for_development
JWT_EXPIRATION=1d
